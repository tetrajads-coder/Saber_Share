<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollStats"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F7"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTituloStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estadisticas"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:paddingBottom="12dp"/>

        <!-- Cards resumen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardCursos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_ios"
                android:padding="16dp"
                android:layout_marginEnd="8dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cursos"
                    android:textColor="#6B7280"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvCursosTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#111111"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvCursosMonto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardClases"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_card_ios"
                android:padding="16dp"
                android:layout_marginStart="8dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clases"
                    android:textColor="#6B7280"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvClasesTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#111111"
                    android:textStyle="bold"
                    android:textSize="26sp"
                    android:layout_marginTop="6dp"/>

                <TextView
                    android:id="@+id/tvClasesMonto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Card grafica barras -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_ios"
            android:padding="16dp"
            android:layout_marginTop="14dp"
            android:elevation="4dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Compras por dia (ultimos 7)"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_marginBottom="10dp"/>

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="220dp"/>
        </LinearLayout>

        <!-- Card grafica pastel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card_ios"
            android:padding="16dp"
            android:layout_marginTop="14dp"
            android:elevation="4dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Distribucion Cursos vs Clases"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_marginBottom="10dp"/>

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="260dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>
