<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    tools:context=".fragmentos.cuenta.RegistroSesion">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        tools:ignore="MissingConstraints">

        <!-- Header iOS -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registro"
            android:textStyle="bold"
            android:textSize="28sp"
            android:textColor="#111827"
            android:textAlignment="center"
            android:letterSpacing="0.02"
            android:paddingTop="10dp"
            android:paddingBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Crea tu cuenta para empezar"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:textAlignment="center"
            android:layout_marginBottom="14dp" />

        <!-- Card container (iOS sheet style) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E5E7EB"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Campo: Usuario -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilUsuario"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Usuario"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeColor="#E5E7EB"
                    app:boxBackgroundColor="@android:color/white"
                    android:layout_marginTop="4dp">

                    <EditText
                        android:id="@+id/etUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Nombre publico -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNombre"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nombre publico"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeColor="#E5E7EB"
                    app:boxBackgroundColor="@android:color/white"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etNombre"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Apellido -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilApellido"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Apellido"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeColor="#E5E7EB"
                    app:boxBackgroundColor="@android:color/white"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etApellido"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Correo -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCorreo"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Correo"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeColor="#E5E7EB"
                    app:boxBackgroundColor="@android:color/white"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etCorreo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:maxLines="1"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Telefono -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTelefono"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Telefono"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeColor="#E5E7EB"
                    app:boxBackgroundColor="@android:color/white"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:maxLines="1"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Campo: Contrasena -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPass"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contraseña"
                    app:endIconMode="password_toggle"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxStrokeColor="#E5E7EB"
                    app:boxBackgroundColor="@android:color/white"
                    android:layout_marginTop="10dp">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botones -->
        <Button
            android:id="@+id/btnRegistrarse"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Registrarse"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="4dp"
            app:cornerRadius="18dp"
            app:backgroundTint="#0C6FCB"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnIniciarSesion"
            android:layout_height="56dp"
            android:layout_width="match_parent"
            android:layout_marginTop="12dp"
            android:backgroundTint="@android:color/white"
            android:text="Iniciar sesion"
            android:textColor="#0C6FCB"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            app:strokeColor="#D1D5DB"
            app:strokeWidth="1dp"
            app:cornerRadius="18dp" />

        <!-- Footer spacing -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=" "
            android:layout_marginBottom="6dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
